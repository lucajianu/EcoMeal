@page "/business/{Id:int}"
@using EcoMeal.Site.Models
@using EcoMeal.Site.Services;



@if(Business is null)
{
    return;
}

<div class="container my-4">
    <h1 class="mb-3">@Business.Name</h1>
    <p class="text-muted mb-4">@Business.Description</p>
    <p class="text-muted mb-4"><strong>Contact:</strong> @Business.Contact</p>
    <p class="text-muted mb-4"><strong>Tip afacere:</strong> @Business.BusinessTypeName</p>
    <p class="text-muted mb-4"><strong>Adresa:</strong> @Business.Address</p>


    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h2 class="mb-0">Pachete</h2>
        <button type="button"
                class="btn btn-primary"
                @onclick="NavigateToAddPackage">
            + Adaugă pachet
        </button >
    </div>

    @if (!Business.Packages.Any())
    {
        <p class="text-secondary">Nu există pachete încă.</p>
    }
    else
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Nume</th>
                    <th>Tip</th>
                    <th>Preț</th>
                    <th>Pick-up</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var package in Business.Packages)
                {
                    <tr>
                        <td>
                            <strong>@package.Name</strong>
                            <div class="text-muted small">@package.Description</div>
                        </td>
                        <td>@package.PackageTypeName</td>
                        <td>@package.Price lei</td>
                        <td>@package.StartPickup.ToString("dd.MM HH:mm") &ndash; @package.EndPickup.ToString("dd.MM HH:mm")</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-secondary me-1"
                                    @onclick="() => NavigateToEditPackage(package.Id)">
                                Editează
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    @onclick="() => DeletePackage(package.Id)">
                                Șterge
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
        [Parameter]
        public int Id { get; set; }

        [Inject]
        public required BusinessService businessService { get; set; }
        [Inject]
        public required PackageService PackageService { get; set; }
        [Inject]
        public required NavigationManager NavigationManager { get; set; }

        private BusinessDetailsModel? Business;

        protected override async Task OnInitializedAsync()
        {
            Business = await businessService.GetOneById(Id);
        }
        public void NavigateToAddPackage(){
                NavigationManager.NavigateTo($"business/{Id}/addPackage");
        }
        public void NavigateToEditPackage(int packageId){
                NavigationManager.NavigateTo($"business/{Id}/editPackage/{packageId}");
        }
        public async Task DeletePackage(int packageId)
        {
            var success = await PackageService.DeletePackageAsync(packageId);
            if (success)
            {
                Business = await businessService.GetOneById(Id);
            }
        }

}
