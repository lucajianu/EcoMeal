@page "/orders"
@using EcoMeal.Client.Models
<PageTitle>Comenzile mele</PageTitle>
<div class="container">
    <h1>Comenzile Mele</h1>
    @if(MyOrders is null){
        <p>Loading...</p>
    }
    else if(!MyOrders.Any()){
        <div class="alert alert-light text-center text-muted">
            Nu ai nicio comanda inca.
        </div>
    }
    else{
        <div class="row g-3">
            @foreach( OrderGetModel order in MyOrders){
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="card-title mb-1">@order.PackageName <span class="text-muted small">x@(order.Count)</span></h5>
                                    <p class="text-muted small">@order.BusinessName</p>
                                    <p class="text-muted small">@order.Date?.ToString("dd.MM.yyyy HH:mm")</p>
                                </div>
                                <div class="text-end">
                                    <span class="badge rounded-pill @StatusBadgeClass(order.Status)">@order.Status</span>
                                    <div class="fw-semibold">@order.Price RON</div>
                                    @if (order.Status == "Pending")
                                    {
                                        <button class="btn btn-sm btn-outline-danger mt-2"
                                                @onclick="() => CancelOrder(order.Id)">
                                            Anulează
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (order.Status == "Finished")
                            {
                                @if (order.ReviewRating is int given)
                                {
                                    <div class="mt-2 pt-2 border-top small">
                                        <span class="text-warning">@Stars(given)</span>
                                        <span class="text-muted ms-1">recenzia ta</span>
                                    </div>
                                }
                                else if (ReviewingOrderId == order.Id)
                                {
                                    <div class="mt-2 pt-2 border-top">
                                        <div class="mb-2">
                                            @for (int star = 1; star <= 5; star++)
                                            {
                                                var value = star;
                                                <button type="button" class="btn btn-link p-0 me-1 text-decoration-none fs-4 @(value <= DraftRating ? "text-warning" : "text-secondary")"
                                                        @onclick="() => DraftRating = value">
                                                    @(value <= DraftRating ? "★" : "☆")
                                                </button>
                                            }
                                        </div>
                                        <textarea class="form-control form-control-sm mb-2" rows="2" maxlength="500"
                                                  placeholder="Spune-ne cum a fost (opțional)"
                                                  @bind="DraftComment"></textarea>
                                        @if (ReviewError is not null)
                                        {
                                            <div class="text-danger small mb-2">@ReviewError</div>
                                        }
                                        <button class="btn btn-sm btn-success me-1" @onclick="() => SubmitReview(order.Id)">Trimite recenzia</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ReviewingOrderId = null">Renunță</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="mt-2 pt-2 border-top">
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => StartReview(order.Id)">
                                            ★ Lasă o recenzie
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
